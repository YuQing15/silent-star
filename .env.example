# ============================================================
# Luminary — Environment Variables
# Copy this file to frontend/.env.local and fill in values.
# The frontend works without any values (uses mock data).
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Luminary

# ── API (backend URL — only needed when connecting FastAPI) ──
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Supabase (only needed for real auth/storage) ─────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Backend only (.env in /backend) ──────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/luminary
SECRET_KEY=change-me-to-a-long-random-string-in-production
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
OPENAI_API_KEY=sk-...
FRONTEND_URL=http://localhost:3000
